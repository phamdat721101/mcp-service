{
  "name": "mcp-service",
  "version": "0.1.0",
  "private": true,
  "description": "n-payment Gateway — paid MCP-as-a-Service. Hosted gateway, facilitator, dashboard, CLI, and reference paid MCP servers.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,sol,yaml,yml}\"",
    "contracts:test": "pnpm -F @n-payment/contracts test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
