# mcp-service env reference. Copy to .env.local and fill in.
# .env.local is gitignored — never commit secrets.

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# ─── Database (Postgres-only — Supabase pgbouncer URL works) ───────────────
# Settings → Database → Connection string → Transaction (pgbouncer, port 6543).
DATABASE_URL=

# ─── Session signing ───────────────────────────────────────────────────────
# Any random ≥32-byte string. `./scripts/run.sh` generates one if missing.
# (For back-compat, the app also accepts SUPABASE_JWT_SECRET.)
SESSION_SECRET=

# ─── Sponsor wallets (testnet only — pgsodium pending in mainnet phase) ────
# Per-chain hot key that submits FeeSplit.settle() on behalf of publishers.
SPONSOR_PK_BASE_SEPOLIA=
SPONSOR_PK_FLARE_COSTON2=
SPONSOR_PK_GOAT_TESTNET3=

# Demo buyer (used by /api/demo/run to sign EIP-3009 client-side).
DEMO_BUYER_PK=

# ─── Contract deployer (Tasks 1 + 7) ───────────────────────────────────────
DEPLOYER_PK=

# ─── RPC overrides (defaults in packages/shared/src/chains.ts) ─────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
FLARE_COSTON2_RPC_URL=https://coston2-api.flare.network/ext/C/rpc
GOAT_TESTNET3_RPC_URL=https://rpc.testnet3.goat.network

# ─── Fee receivers (filled per chain after Task 7 deploy) ──────────────────
GATEWAY_FEE_RECEIVER_BASE_SEPOLIA=
GATEWAY_FEE_RECEIVER_FLARE_COSTON2=
GATEWAY_FEE_RECEIVER_GOAT_TESTNET3=

# ─── Aave (Task 6) ─────────────────────────────────────────────────────────
AAVE_AUTO_YIELD=true

# ─── Cron auth (protects /api/cron/*) ──────────────────────────────────────
CRON_BEARER=
